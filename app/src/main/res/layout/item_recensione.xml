<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp">

    <FrameLayout
        android:id="@+id/frameAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/ic_user"
        android:backgroundTint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/lblNomeUtente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="@font/chakra_petch_semibold"
        android:textColor="@color/black"
        android:textSize="15sp"
        app:layout_constraintEnd_toStartOf="@+id/lblDataRecensione"
        app:layout_constraintStart_toEndOf="@+id/frameAvatar"
        app:layout_constraintTop_toTopOf="@+id/frameAvatar"
        tools:text="Mario Rossi" />

    <ImageButton
        android:id="@+id/btnEliminaRecensione"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Elimina recensione"
        android:src="@android:drawable/ic_menu_delete"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/lblNomeUtente"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/lblNomeUtente"
        app:tint="#CC3838"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/lblDataRecensione"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/dm_sans_medium"
        android:textColor="#999999"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/lblNomeUtente"
        app:layout_constraintEnd_toStartOf="@+id/btnEliminaRecensione"
        app:layout_constraintTop_toTopOf="@+id/lblNomeUtente"
        tools:text="2 gg fa" />

    <RatingBar
        android:id="@+id/ratingSingolo"
        style="@android:style/Widget.Material.RatingBar.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:numStars="5"
        android:progressTint="@color/fuelly_green_dark"
        android:secondaryProgressTint="@android:color/transparent"
        android:stepSize="1.0"
        app:layout_constraintStart_toStartOf="@+id/lblNomeUtente"
        app:layout_constraintTop_toBottomOf="@+id/lblNomeUtente"
        tools:rating="4" />

    <TextView
        android:id="@+id/lblTestoRecensione"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/dm_sans_medium"
        android:lineSpacingExtra="2dp"
        android:textColor="#444444"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/lblNomeUtente"
        app:layout_constraintTop_toBottomOf="@+id/ratingSingolo"
        tools:text="Ottimo distributore, prezzi onesti e personale molto gentile." />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#F0F0F0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/lblNomeUtente"
        app:layout_constraintTop_toBottomOf="@+id/lblTestoRecensione" />

</androidx.constraintlayout.widget.ConstraintLayout>