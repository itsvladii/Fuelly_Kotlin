<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ui.salvati.SalvatiFragment">

    <View
        android:id="@+id/headerView"
        android:layout_width="414dp"
        android:layout_height="152dp"
        android:background="@drawable/bg_header_cerca"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="194dp"
        android:layout_height="126dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="50dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/chakra_petch_semibold"
            android:text="@string/saved_title"
            android:textColor="#DFFF00"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/textViewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans_medium"
            android:text="@string/saved_subtitle"
            android:textColor="#B0FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroupSalvati"
        android:layout_width="350dp"
        android:layout_height="38dp"
        android:layout_marginTop="160dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerView"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvatiBenzina"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:drawableTint="@color/black"
            android:fontFamily="@font/dm_sans_medium"
            android:text="@string/saved_tab_benzinai"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textSize="13sp"
            app:backgroundTint="@color/chip_background_selector_benzinai"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_fuel"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/grey_inactive"
            app:strokeColor="@color/ic_launcher_background"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvatiEV"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:drawableTint="@color/black"
            android:fontFamily="@font/dm_sans_medium"
            android:text="@string/saved_tab_ev"
            android:textColor="@color/black"
            android:textSize="13sp"
            app:backgroundTint="@color/chip_background_selector_ev"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_ev_logo"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/grey_inactive"
            app:strokeColor="#00FFC2"
            app:strokeWidth="1.5dp" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSalvati"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="60dp"
        android:clipToPadding="false"
        android:padding="8dp"
        android:paddingBottom="130dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerView"
        tools:listitem="@layout/item_benzinaio" />

    <View
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/bg_bottom_fade_gradient"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>