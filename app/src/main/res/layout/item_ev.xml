<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FDFDFD">

<androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/frameIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/ev_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgTipoPresa"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ev_logo"
                app:tint="#0B3D2E" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layoutInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/layoutStato"
            app:layout_constraintStart_toEndOf="@+id/frameIcon"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/lblNomePresa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/chakra_petch_semibold"
                android:text="Type 2 (Mennekes)"
                android:textColor="#1A1A1A"
                android:textSize="15sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/lblPotenza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans_medium"
                android:text="2 connettori • 22 kW"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/viewStatoColore"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_status_ev" />

            <TextView
                android:id="@+id/lblStatoPresa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/chakra_petch_semibold"
                android:text="ONLINE"
                android:textColor="#2E7D32"
                android:textSize="10sp"
                android:letterSpacing="0.05" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>