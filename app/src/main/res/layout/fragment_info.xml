<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nome Gestore - Reso più evidente -->
            <TextView
                android:id="@+id/textNomeBenzinaio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Gestore Impianto"
                android:textAlignment="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <!-- Orari - Spaziati meglio -->
            <TextView
                android:id="@+id/textOrarioApertura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Orario Apertura"
                android:textAlignment="center"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textOrarioChiusura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Orario Chiusura"
                android:textAlignment="center"
                android:textSize="16sp" />

            <!-- Divider visivo opzionale tramite margin -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#DDDDDD" />

            <!-- Switch - Allineati e distanziati -->
            <Switch
                android:id="@+id/switchBagno"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="8dp"
                android:text="Servizi Igienici"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switchBar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="8dp"
                android:text="Servizi Ristorazione"
                android:textSize="16sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <!-- Descrizione - Occupa lo spazio rimanente -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/DescEstesa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:hint="Descrizione del posto"
                    android:inputType="textMultiLine"
                    android:minLines="5" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>