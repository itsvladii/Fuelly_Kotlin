<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/containerAzioni"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- INTESTAZIONE -->
            <TextView
                android:id="@+id/textNomeBenzinaio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/chakra_petch_semibold"
                android:text="@string/info_manager_name"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="24sp" />

            <View
                android:layout_width="50dp"
                android:layout_height="3dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@color/fuelly_green_dark" />

            <!-- CARD ORARI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/dm_sans_medium"
                        android:text="@string/info_service_hours"
                        android:textColor="@color/fuelly_green_dark"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:hint="Apertura"
                            android:textColorHint="@color/grey_inactive"
                            app:boxStrokeColor="@color/grey_inactive"
                            app:cursorColor="@color/fuelly_green_dark"
                            app:helperTextTextColor="@color/fuelly_green_dark"
                            app:hintTextColor="@color/fuelly_green_dark">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/textOrarioApertura"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="time"
                                android:textColor="@color/fuelly_green_dark"
                                android:textColorHint="@color/fuelly_green_dark" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Chiusura"
                            android:textColorHint="@color/grey_inactive"
                            app:boxStrokeColor="@color/grey_inactive"
                            app:cursorColor="@color/fuelly_green_dark"
                            app:helperTextTextColor="@color/fuelly_green_dark"
                            app:hintTextColor="@color/fuelly_green_dark">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/textOrarioChiusura"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="time"
                                android:textColor="@color/fuelly_green_dark"
                                android:textColorHint="@color/fuelly_green_dark" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD SERVIZI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchBagno"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans_medium"
                        android:text="@string/info_toilets"
                        android:textColor="@color/fuelly_green_dark"
                        app:switchPadding="16dp"
                        app:thumbTint="@color/fuelly_green_dark"
                        app:trackTint="@color/fuelly_yellow_fluo" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans_medium"
                        android:text="@string/info_bar"
                        android:textColor="@color/fuelly_green_dark"
                        app:switchPadding="16dp"
                        app:thumbTint="@color/fuelly_green_dark"
                        app:trackTint="@color/fuelly_yellow_fluo" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DESCRIZIONE -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Note e Descrizione"
                android:textColorHint="@color/grey_inactive"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/grey_inactive"
                app:cursorColor="@color/fuelly_green_dark"
                app:hintTextColor="@color/fuelly_green_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/DescEstesa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dm_sans_medium"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:textColor="@color/fuelly_green_dark"
                    android:textColorHint="@color/ic_launcher_background" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BARRA AZIONI IN BASSO -->
    <LinearLayout
        android:id="@+id/containerAzioni"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/editButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="49dp"
            android:layout_weight="1.5"
            android:drawableTint="@color/fuelly_green_dark"
            android:drawableTintMode="add"
            android:text="@string/edit"
            android:textColor="@color/fuelly_green_dark"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_edit"
            app:iconTint="@color/black" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/segnalaButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="49dp"
            android:layout_weight="1.5"
            android:drawableTint="@color/white"
            android:drawableTintMode="add"
            android:text="@string/report"
            android:textColor="@color/white"
            app:backgroundTint="#CC3838"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/stat_sys_warning"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="0dp"
            android:layout_height="49dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1.5"
            android:fontFamily="@font/chakra_petch_semibold"
            android:text="@string/save"
            android:textColor="@color/black"
            app:backgroundTint="#DFFF00"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_save"
            app:iconTint="@color/black" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>