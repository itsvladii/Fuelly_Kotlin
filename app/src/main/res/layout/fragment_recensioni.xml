<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Valutazioni -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/txtMediaVoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/chakra_petch_semibold"
                android:text="0.0"
                android:textColor="#1A1A1A"
                android:textSize="48sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <RatingBar
                android:id="@+id/ratingMedia"
                style="@android:style/Widget.Material.RatingBar.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:numStars="5"
                android:rating="0.0"
                android:progressTint="#0B3D2E"
                app:layout_constraintBottom_toBottomOf="@+id/txtMediaVoto"
                app:layout_constraintStart_toEndOf="@+id/txtMediaVoto"
                app:layout_constraintTop_toTopOf="@+id/txtMediaVoto" />

            <Button
                android:id="@+id/btnScriviRecensione"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/fuelly_yellow_fluo"
                android:fontFamily="@font/chakra_petch_semibold"
                android:text="SCRIVI \nRECENSIONE"
                android:textColor="#0B3D2E"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp"/>

        <!-- Stato Vuoto (quello che vedi nel tuo screenshot) -->
        <TextView
            android:id="@+id/txtNessunaRecensione"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="Nessuna recensione disponibile"
            android:fontFamily="@font/dm_sans_medium"
            android:textColor="#999999"
            android:visibility="gone" />

        <!-- Lista Recensioni -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecensioni"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>