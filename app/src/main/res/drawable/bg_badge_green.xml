<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/bg_badge_green.xml
    Badge pill usato per i valori live degli slider (potenza kW, raggio km)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#2900FFC2" />

    <stroke
        android:width="1dp"
        android:color="#6600FFC2" />

    <corners android:radius="100dp" />

    <padding
        android:bottom="2dp"
        android:left="8dp"
        android:right="8dp"
        android:top="2dp" />
</shape>