<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Fuelly" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fuelly_green_dark</item>

        <item name="colorAccent">@color/fuelly_yellow_fluo</item>

        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/fuelly_yellow_fluo</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Questo cambierà il cursore, le checkbox e i bottoni attivati -->
        <item name="colorControlActivated">#DFFF00</item>
        <!-- Colore specifico per l'evidenziazione del testo selezionato -->
        <item name="android:textColorHighlight">#40DFFF00</item>
    </style>

    <style name="WhiteSearchViewText" parent="Widget.AppCompat.SearchView">
        <item name="android:editTextColor">#FFFFFF</item>
        <item name="android:textColorHint">#888888</item>
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="drawableTint">#FFFFFF</item>
    </style>

    <style name="Theme.Fuelly" parent="Base.Theme.Fuelly" />
</resources>